# Thông tin kết nối Database
MONGO_URI=your_mongodb_connection_string_here

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# Stripe Payment
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Cloudinary (Image/Video Upload)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (Nodemailer)
# Required variables:
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_FROM=Oncademy <your-email@gmail.com>

# Optional SMTP Settings (defaults to Gmail if not specified)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Optional: Override recipient in development mode for testing
# EMAIL_TEST_RECIPIENT=test-email@example.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development
